;   param=value ; assign values to parameters

config_version=5

[application]

config/name="CleanerNDSVersion"
run/main_scene="uid://c2jo1f6jebhab"
config/features=PackedStringArray("4.6", "Mobile")
config/icon="res://icon.svg"

[autoload]

CombatFx="*uid://dftahvy4iqilp"

[display]

window/size/viewport_width=320
window/size/viewport_height=180
window/size/mode=2
window/size/always_on_top=true
window/stretch/mode="canvas_items"
window/stretch/scale_mode="integer"

[global_group]

enemies=""
player=""

[input]

move_left={
"deadzone": 0.2,
"events": [Object(InputEventJoypadMotion,"resource_local_to_scene":false,"resource_name":"","device":-1,"axis":0,"axis_value":-1.0,"script":null)
]
}
move_right={
"deadzone": 0.2,
"events": [Object(InputEventJoypadMotion,"resource_local_to_scene":false,"resource_name":"","device":-1,"axis":0,"axis_value":1.0,"script":null)
]
}
jump={
"deadzone": 0.2,
"events": [Object(InputEventJoypadButton,"resource_local_to_scene":false,"resource_name":"","device":-1,"button_index":0,"pressure":0.0,"pressed":true,"script":null)
]
}
shoot={
"deadzone": 0.2,
"events": [Object(InputEventJoypadButton,"resource_local_to_scene":false,"resource_name":"","device":-1,"button_index":1,"pressure":0.0,"pressed":true,"script":null)
]
